# Local API
PORT=4100
PUBLIC_SITE_URL=https://kerodexofficial.com
ADMIN_ACCESS_CODE=change-this-local-admin-code
ADMIN_EMAIL=founder@kerodexofficial.com

# Google OAuth
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Microsoft OAuth
MICROSOFT_CLIENT_ID=your-microsoft-application-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
# Use "common" for consumer + work/school accounts, "organizations" for work/school only,
# "consumers" for personal Microsoft accounts only, or a tenant ID.
MICROSOFT_TENANT_ID=common

# Email verification through Resend
RESEND_API_KEY=your-resend-api-key
AUTH_EMAIL_FROM=Kerodex <verify@kerodexofficial.com>

# Twilio Verify phone OTP. Configure the SMS template in Twilio Verify as:
# "Your Kerodex verification code is {{code}}. It expires in 10 minutes. Do not share this code."
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# MarketCheck backend-only API credentials
MARKETCHECK_API_KEY=
COST_OPENAI_VEHICLE_VERIFICATION=0.01
COST_PERSONA_VERIFICATION=1.00
COST_TWILIO_SMS_VERIFICATION=0.05
COST_MARKETCHECK_REQUEST=0.01
COST_S3_UPLOAD_ESTIMATE=0.001
MARKETCHECK_CLIENT_SECRET=
MARKETCHECK_REFRESH_DAYS=14

# Persona hosted identity verification. Disabled in the current beta until a
# signed webhook and server-authoritative inquiry decision flow are implemented.
PERSONA_INQUIRY_TEMPLATE_ID=PASTE_TEMPLATE_ID_HERE
# Optional alias supported by the backend:
PERSONA_TEMPLATE_ID=
PERSONA_API_KEY=

# Database. Set REQUIRE_DATABASE=true in production so the API fails fast if
# DATABASE_URL is missing instead of falling back to local JSON seed data.
DATABASE_URL=postgres://user:password@host:5432/database
DATABASE_SSL=true
REQUIRE_DATABASE=false

# S3 uploads. Keep the bucket private; use CloudFront or another controlled delivery base for S3_PUBLIC_BASE_URL.
AWS_REGION=us-east-1
S3_BUCKET=your-kerodex-upload-bucket
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# Optional vehicle presence AI review. If OPENAI_API_KEY is blank, submitted
# presence photos are saved but routed to manual admin review instead of auto-publishing.
OPENAI_API_KEY=
VEHICLE_PRESENCE_MODEL=gpt-4o-mini
VEHICLE_PRESENCE_CODE_HOURS=36

# Optional Buyer Guide recommendation model. Uses OPENAI_API_KEY on the backend.
# If unavailable, Kerodex automatically uses deterministic fallback recommendations.
BUYER_GUIDE_MODEL=gpt-4o-mini
# Optional separate key; OPENAI_API_KEY remains the default.
BUYER_GUIDE_OPENAI_API_KEY=
