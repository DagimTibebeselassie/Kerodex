# Local API
PORT=4100
ADMIN_PORT=4101
ADMIN_ACCESS_CODE=change-this-local-admin-code

# Google OAuth
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Microsoft OAuth
MICROSOFT_CLIENT_ID=your-microsoft-application-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
# Use "common" for consumer + work/school accounts, "organizations" for work/school only,
# "consumers" for personal Microsoft accounts only, or a tenant ID.
MICROSOFT_TENANT_ID=common

# Email verification through Resend
RESEND_API_KEY=your-resend-api-key
AUTH_EMAIL_FROM=Caridex <verify@caridexofficial.com>

# Optional SMS phone verification through Twilio. If blank, local development
# returns a dev code but production should configure these before enabling phone verification.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=

# MarketCheck backend-only API credentials
MARKETCHECK_API_KEY=
MARKETCHECK_CLIENT_SECRET=
MARKETCHECK_REFRESH_DAYS=14

# Persona hosted identity verification
PERSONA_INQUIRY_TEMPLATE_ID=PASTE_TEMPLATE_ID_HERE
# Optional alias supported by the backend:
PERSONA_TEMPLATE_ID=
PERSONA_API_KEY=

# Database. Set REQUIRE_DATABASE=true in production so the API fails fast if
# DATABASE_URL is missing instead of falling back to local JSON seed data.
DATABASE_URL=postgres://user:password@host:5432/database
DATABASE_SSL=true
REQUIRE_DATABASE=false

# S3 uploads. Keep the bucket private; use CloudFront or another controlled delivery base for S3_PUBLIC_BASE_URL.
AWS_REGION=us-east-1
S3_BUCKET=your-kerodex-upload-bucket
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# Optional AWS Textract OCR checks for uploaded maintenance/title documents.
# These can reuse AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY above, or use
# the Textract-specific overrides below.
TEXTRACT_AWS_REGION=us-east-2
TEXTRACT_AWS_ACCESS_KEY_ID=
TEXTRACT_AWS_SECRET_ACCESS_KEY=
TEXTRACT_POLL_INTERVAL_MS=1500

# Optional vehicle presence AI review. If OPENAI_API_KEY is blank, submitted
# presence photos are saved but routed to manual admin review instead of auto-publishing.
OPENAI_API_KEY=
VEHICLE_PRESENCE_MODEL=gpt-4o-mini
VEHICLE_PRESENCE_CODE_HOURS=36
